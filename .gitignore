# =======================================================
# MERN Stack .gitignore
# =======================================================

# -------------------------------------------------------
# Node.js / Express (Server-side)
# -------------------------------------------------------

# Dependencies
node_modules/

# Environment variables
# NEVER commit your secrets, API keys, or database URIs
.env
.env.local
.env.development
.env.production
.env.test

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# -------------------------------------------------------
# React (Client-side)
# -------------------------------------------------------
# Assumes your React app is in a folder named 'client/'. 
# If it's 'frontend/', 'app/', etc., just rename the path.

# Dependencies
client/node_modules/

# Production build
client/build/
server/node_modules/

# Environment variables
client/.env
client/.env.local
client/.env.development
client/.env.production
client/.env.test

# CRA / Vite local files
client/.pnp
client/.pnp.js
client/.npm
client/.vite/
client/.vite/cache/

# -------------------------------------------------------
# General / OS / IDE
# -------------------------------------------------------

# Operating System files
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# IDE & Editor specific
.idea/
.vscode/
*.swp
*.swo

# Test & Coverage
coverage/
.nyc_output/

# Misc
.npm